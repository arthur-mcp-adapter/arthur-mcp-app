{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqpm" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "targets": [{ "expr": "sum(rate(http_requests_total[1m])) * 60", "legendFormat": "requests/min" }],
      "title": "Requests per minute",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqpm" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "targets": [{ "expr": "sum(rate(http_requests_errors_total[1m])) * 60", "legendFormat": "errors/min" }],
      "title": "Errors per minute",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "targets": [{ "expr": "sum(rate(http_request_duration_seconds_sum[5m])) / sum(rate(http_request_duration_seconds_count[5m]))", "legendFormat": "avg" }],
      "title": "Average latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }],
      "title": "Latency p95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 7 },
      "id": 5,
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }],
      "title": "Latency p99",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 7 },
      "id": 6,
      "targets": [{ "expr": "rate(process_cpu_user_seconds_total[5m]) + rate(process_cpu_system_seconds_total[5m])", "legendFormat": "cpu" }],
      "title": "CPU usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 7 },
      "id": 7,
      "targets": [{ "expr": "process_resident_memory_bytes", "legendFormat": "rss" }, { "expr": "nodejs_heap_size_used_bytes", "legendFormat": "heap used" }],
      "title": "Memory usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 7 },
      "id": 8,
      "targets": [{ "expr": "nodejs_eventloop_lag_seconds", "legendFormat": "event loop lag" }],
      "title": "Event loop lag",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 14 },
      "id": 9,
      "targets": [{ "expr": "topk(10, sum by (tool_name) (increase(mcp_tool_calls_total[1h])))", "legendFormat": "{{tool_name}}" }],
      "title": "Most called MCP tools",
      "type": "barchart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 14 },
      "id": 10,
      "targets": [{ "expr": "topk(10, sum by (tool_name) (increase(mcp_tool_errors_total[1h])))", "legendFormat": "{{tool_name}}" }],
      "title": "MCP tools with most errors",
      "type": "barchart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 14 },
      "id": 11,
      "targets": [{ "expr": "sum by (tool_name) (rate(mcp_tool_duration_seconds_sum[5m])) / sum by (tool_name) (rate(mcp_tool_duration_seconds_count[5m]))", "legendFormat": "{{tool_name}}" }],
      "title": "Average duration by tool",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 21 },
      "id": 12,
      "targets": [{ "expr": "topk(10, sum by (resource_name) (increase(mcp_resource_reads_total[1h])))", "legendFormat": "{{resource_name}}" }],
      "title": "Most read resources",
      "type": "barchart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 21 },
      "id": 13,
      "targets": [{ "expr": "sum by (provider) (rate(mcp_external_http_requests_total[5m]))", "legendFormat": "{{provider}}" }],
      "title": "External HTTP calls",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 21 },
      "id": 14,
      "targets": [{ "expr": "sum by (provider) (rate(mcp_external_http_errors_total[5m]))", "legendFormat": "{{provider}}" }],
      "title": "External HTTP errors",
      "type": "timeseries"
    }
  ],

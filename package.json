{
  "name": "mcp-server",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "client"
  ],
  "scripts": {
    "install:all": "npm install && npm install --prefix client",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "npm run start:dev",
    "dev:backend": "rm -f tsconfig.tsbuildinfo && nest start --watch",
    "dev:frontend": "npm run start:dev --prefix client",
    "build": "npm run clean && npm run build:backend && npm run build:frontend",
    "build:backend": "rm -f tsconfig.tsbuildinfo && nest build",
    "build:frontend": "npm run build --prefix client",
    "start": "node dist/main",
    "start:dev": "concurrently --kill-others-on-fail \"npm run dev:backend\" \"wait-on http://localhost:3000/health && npm run dev:frontend\"",
    "start:frontend": "npm run start --prefix client",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json --forceExit",
    "kill:dev": "kill -9 $(lsof -t -i:3000) 2>/dev/null; kill -9 $(lsof -t -i:5173) 2>/dev/null; true"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/typeorm": "^11.0.2",
    "@rekog/mcp-nest": "1.9.10",
    "@types/nodemailer": "^8.0.1",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "hbs": "^4.2.1",
    "http-proxy-middleware": "^3.0.6",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.0",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.11",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.30",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.2.0",
    "concurrently": "^8.2.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0",
    "wait-on": "^9.0.10"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {}
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/main.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/../test/setup.ts"
    ]
  }
}

# .env.example
#
# Copy this file to .env and fill in the values before running locally.
# When using Docker Compose WITHOUT a .env file, the defaults defined
# in docker-compose.yml are used automatically (safe for development only).
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  REQUIRED FOR PRODUCTION — change every value marked (!)               │
# └─────────────────────────────────────────────────────────────────────────┘

# ── Server ───────────────────────────────────────────────────────────────────
# Port the NestJS process listens on inside the container.
# On Railway/Render this is overridden by the platform automatically.
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Choose the storage backend:
#   sqlite     — local file, zero setup (default, ideal for development)
#   mysql      — MySQL 8+ or MariaDB 10.6+
#   postgres   — PostgreSQL 14+  (also accepts 'postgresql')
#   mongodb    — MongoDB 6+ (Mongoose, separate schema)
DATABASE=sqlite

# ── SQLite (used when DATABASE=sqlite) ───────────────────────────────────────
# File path for the SQLite database. In Docker, point to the mounted volume:
# SQLITE_PATH=/app/data/database.sqlite
SQLITE_PATH=database.sqlite

# ── MySQL / PostgreSQL (required when DATABASE=mysql or DATABASE=postgres) ───
# (!) Use strong, unique credentials in production.
# DB_HOST=localhost
# DB_PORT=3306        # MySQL default; PostgreSQL default is 5432
# DB_USER=mcp
# DB_PASSWORD=mcppassword
# DB_NAME=mcp_db
# DB_SSL=false

# DB_SYNC controls TypeORM synchronize option for MySQL / PostgreSQL.
# (!) NEVER set DB_SYNC=true in production — TypeORM may drop columns and
#     destroy data when the schema diverges. Use migrations instead.
# DB_SYNC=false

# ── MongoDB (required when DATABASE=mongodb) ──────────────────────────────────
# Docker Compose (self-hosted): set MONGO_USER / MONGO_PASSWORD / MONGO_DB.
# Atlas / Railway / Render: set MONGODB_URI directly.
#
# (!) Use strong, unique values in production.
# MONGODB_URI=mongodb://mcp:mcppassword@localhost:27017/mcp_db?authSource=admin
# For Atlas: mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/mcp_db

# ── Dashboard ────────────────────────────────────────────────────────────────
# Credentials for the admin dashboard user.
# (!) Change the password in production.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=admin

# ── JWT ──────────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Must be long and random in production.
# Used as the bootstrap/fallback value; Settings can store a database-backed
# replacement at runtime.
# (!) Generate a strong secret:
#     openssl rand -hex 64
JWT_SECRET=dev-jwt-secret-change-in-production

# ── Observability ─────────────────────────────────────────────────────────────
# Operational endpoints are exposed at /health, /ready, /live, and /metrics.
ENABLE_STRUCTURED_LOGS=true
ENABLE_METRICS=true
LOG_LEVEL=info
SERVICE_NAME=arthur-mcp-adapter
SERVICE_VERSION=1.0.0
PROMETHEUS_METRICS_PATH=/metrics

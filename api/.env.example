# .env.example
#
# Copy this file to .env and fill in the values before running locally.
# When using Docker Compose WITHOUT a .env file, the defaults defined
# in docker-compose.yml are used automatically (safe for development only).
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  REQUIRED FOR PRODUCTION — change every value marked (!)               │
# └─────────────────────────────────────────────────────────────────────────┘

# ── Server ───────────────────────────────────────────────────────────────────
# Port the NestJS process listens on inside the container.
# On Railway/Render this is overridden by the platform automatically.
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_URI is a single connection string. The driver (sqlite/postgres/mysql)
# is auto-detected from its scheme — there is no separate DATABASE variable.
#   sqlite:<path>              — local file, zero setup (default, ideal for development)
#   postgres://user:pass@host:5432/db_name[?sslmode=require]   — PostgreSQL 14+
#   mysql://user:pass@host:3306/db_name[?ssl=true]             — MySQL 8+ / MariaDB 10.6+
DATABASE_URI=sqlite:database.sqlite
# In Docker, point to the mounted volume:
# DATABASE_URI=sqlite:/app/data/database.sqlite
# PostgreSQL example:
# DATABASE_URI=postgres://mcp:mcppassword@localhost:5432/mcp_db
# MySQL example:
# DATABASE_URI=mysql://mcp:mcppassword@localhost:3306/mcp_db

# DB_SYNC is deprecated and ignored. TypeORM synchronize is disabled for every
# driver. All database schema/data changes must be shipped through migrations.
# DB_SYNC=false

# ── JWT ──────────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Must be long and random in production.
# (!) Generate a strong secret:
#     openssl rand -hex 64
JWT_SECRET=dev-jwt-secret-change-in-production

# ── Deployment mode ────────────────────────────────────────────────────────────
# Set to true only for self-hosted instances where a single operator should be
# able to edit the Administration section (Settings/Error Tracking) from the UI.
# On the hosted platform this stays false — that section is read-only for
# tenants and configured only through the env vars below.
SELF_HOSTED=false

# Public base URL of this deployment. Used to build links in emails (password
# reset, digests) and shown read-only under Settings → Server.
APP_URL=http://localhost:3000

# ── E-mail (optional) ────────────────────────────────────────────────────────
# Leave blank to disable email sending — password reset links are logged
# instead of emailed, and digest/alert emails are skipped.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Global request headers (optional) ────────────────────────────────────────
# JSON array of {name, value} pairs injected into every outbound HTTP request
# made by dynamic MCP servers (e.g. a shared proxy/tracing header).
# GLOBAL_REQUEST_HEADERS=[{"name":"X-Proxy-Token","value":"..."}]

# ── Social sign-in (optional) ─────────────────────────────────────────────────
# Leave blank to hide the corresponding button — the app runs fine without them.
# Google: console.cloud.google.com/apis/credentials → OAuth client ID (Web application)
#   Authorized redirect URI: <your-public-url>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: github.com/settings/developers → OAuth Apps → New OAuth App
#   Authorization callback URL: <your-public-url>/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Supabase Auth sign-in (optional) ──────────────────────────────────────────
# Leave SUPABASE_URL blank to disable — the app runs fine without it. When set,
# a client presenting a valid Supabase Auth JWT (Authorization: Bearer <token>)
# is accepted as an alternative to our own JWT, same as Google/GitHub sign-in:
# it's linked/created against our own `users` table by email.
# Only SUPABASE_URL + a JWKS source are required for this (verification only,
# no writes to your Supabase project). Get these from
# Project Settings → API in the Supabase dashboard.
SUPABASE_URL=
SUPABASE_JWKS_URL=
# Only needed if some other part of the app calls the Supabase API directly:
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
# Operational endpoints are exposed at /health, /ready, /live, and /metrics.
ENABLE_STRUCTURED_LOGS=true
ENABLE_METRICS=true
LOG_LEVEL=info
SERVICE_NAME=arthur-mcp-adapter
SERVICE_VERSION=1.0.0
PROMETHEUS_METRICS_PATH=/metrics

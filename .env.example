# ── Servidor ────────────────────────────────────────────────────────────────
# Porta em que o NestJS escuta (dentro do container)
PORT=3000

# ── Autenticação MCP ────────────────────────────────────────────────────────
# Chave de API usada para autenticar chamadas ao servidor MCP
MCP_API_KEY=troque-por-uma-chave-forte

# ── API externa ─────────────────────────────────────────────────────────────
# URL base da API que o servidor consome como exemplo/proxy
EXTERNAL_API_BASE_URL=https://jsonplaceholder.typicode.com

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Credenciais do banco — usadas tanto pelo serviço mongo quanto pelo app
MONGO_USER=mcp
MONGO_PASSWORD=troque-por-senha-forte
MONGO_DB=mcp_db

# MONGODB_URI é montada automaticamente no docker-compose usando as vars acima.
# Use esta variável apenas para conexão direta (fora do Docker):
# MONGODB_URI=mongodb://mcp:<senha>@localhost:27017/mcp_db?authSource=admin

# ── Dashboard ────────────────────────────────────────────────────────────────
# Credenciais do usuário administrador do dashboard
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=troque-por-senha-forte

# ── JWT ──────────────────────────────────────────────────────────────────────
# Segredo usado para assinar tokens JWT — deve ser longo e aleatório em produção
JWT_SECRET=troque-por-um-segredo-forte-em-producao

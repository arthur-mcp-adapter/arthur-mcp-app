{
  "_comment": "Static React frontend on Vercel. The backend (NestJS) must be running on Render (or another host). Replace YOUR_RENDER_URL below with your Render service URL, e.g. https://mcp-server.onrender.com",
  "buildCommand": "cd client && npm ci && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm ci --prefix client",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_RENDER_URL/api/:path*"
    },
    {
      "source": "/mcp/:path*",
      "destination": "https://YOUR_RENDER_URL/mcp/:path*"
    },
    {
      "source": "/health",
      "destination": "https://YOUR_RENDER_URL/health"
    },
    {
      "source": "/mcp-docs/:path*",
      "destination": "https://YOUR_RENDER_URL/mcp-docs/:path*"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}

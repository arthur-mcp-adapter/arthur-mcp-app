{
  "_comment": "This config is only needed if you want to deploy the React frontend as a standalone static site on Vercel. For a full-stack deploy (frontend + backend + database together), use docker compose up, Railway, or Render instead.",
  "framework": "vite",
  "buildCommand": "cd client && npm install && npm run build -- --outDir dist",
  "outputDirectory": "client/dist",
  "installCommand": "npm install --prefix client",
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
